{
  "swagger": "2.0",
  "info": {
    "title": "FountTech API Documentation",
    "version": "1.0.0",
    "description": "This is an API for storing and retrieving information about startups. These business data are to be stored in a MongoDB database and all interaction happen through the API. The API can be used by any frontend.",
    "author": "Baron T.",
    "Last update": "2026-05-21"
  },
  "host": "localhost:8080",
  "basePath": "/",
  "schemes": [
    "http",
    "https"
  ],
  "paths": {
    "/": {
      "get": {
        "tags": [
          "Home Page"
        ],
        "description": "",
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/startups/": {
      "get": {
        "tags": [
          "startups CRUD Operations"
        ],
        "summary": "Get All startups",
        "description": "Pull all startups from the database. ",
        "responses": {
          "200": {
            "description": "OK"
          },
          "404": {
            "description": "Not Found"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      },
      "post": {
        "tags": [
          "startups CRUD Operations"
        ],
        "summary": "Create New Startup",
        "description": "Insert new startup in the database. ",
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "description": "Enter New startup",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "firstName": {
                  "type": "string",
                  "example": "John"
                },
                "lastName": {
                  "type": "string",
                  "example": "Doe"
                },
                "email": {
                  "type": "string",
                  "example": "john@domain.com"
                },
                "favoriteColor": {
                  "type": "string",
                  "example": "color"
                },
                "birthday": {
                  "type": "string",
                  "example": "Jan 1"
                }
              }
            }
          }
        ],
        "responses": {
          "201": {
            "description": "Created"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    },
    "/startups/{id}": {
      "get": {
        "tags": [
          "startups CRUD Operations"
        ],
        "summary": "Get single startup",
        "description": "Pull one startup by ID from the database. ",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string",
            "description": "startup ID"
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "404": {
            "description": "Not Found"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      },
      "put": {
        "tags": [
          "Startups CRUD Operations"
        ],
        "summary": "Update Startup Info",
        "description": "Edit a specific startup and save update in database. ",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string",
            "description": "Startup ID"
          },
          {
            "name": "body",
            "in": "body",
            "description": "Updated startup fields",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "firstName": {
                  "type": "string",
                  "example": "Jane"
                },
                "lastName": {
                  "type": "string",
                  "example": "Doe"
                },
                "email": {
                  "type": "string",
                  "example": "jane@domain.com"
                },
                "favoriteColor": {
                  "type": "string",
                  "example": "blue"
                },
                "birthday": {
                  "type": "string",
                  "example": "Feb 2"
                }
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      },
      "delete": {
        "tags": [
          "startups CRUD Operations"
        ],
        "summary": "Delete startup",
        "description": "Delete selected startup from the database.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string",
            "description": "startup ID"
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    }
  }
}