{
  "swagger": "2.0",
  "info": {
    "title": "FountTech API Documentation",
    "version": "1.0.0",
    "description": "This is an API for storing and retrieving information about local startups in Kinshasa. These businesses' data are accessible through the API which can be used by any frontend. The API is built using Node.js and Express, and the documentation is generated using Swagger. The API provides endpoints for creating, reading, updating, and deleting startup information, as well as searching for startups based on various criteria. The documentation includes details about each endpoint, including the request parameters, response format, and example requests and responses. ",
    "author": "Baron T.",
    "last update": "2026-05-22"
  },
  "host": "localhost:8080",
  "basePath": "/",
  "schemes": [
    "http",
    "https"
  ],
  "paths": {
    "/startups/": {
      "get": {
        "tags": [
          "Startups Endpoints"
        ],
        "summary": "Get all startups",
        "description": "Pull all startups from the database. ",
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      },
      "post": {
        "tags": [
          "Startups Endpoints"
        ],
        "summary": "Create a new startup",
        "description": "Insert new startup in the database. ",
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "description": "New startup data",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string",
                  "example": "KongoTech"
                },
                "description": {
                  "type": "string",
                  "example": "FinTech startup providing digital payment solutions"
                },
                "industry": {
                  "type": "string",
                  "example": "FinTech"
                },
                "founders": {
                  "type": "array",
                  "example": [
                    "Baron Mobs"
                  ],
                  "items": {
                    "type": "string"
                  }
                },
                "foundedYear": {
                  "type": "number",
                  "example": 2022
                },
                "location": {
                  "type": "object",
                  "properties": {
                    "ward": {
                      "type": "string",
                      "example": "Ngiri-Ngiri"
                    },
                    "stake": {
                      "type": "string",
                      "example": "Kinshasa"
                    },
                    "commune": {
                      "type": "string",
                      "example": "Ngiri-Ngiri"
                    },
                    "city": {
                      "type": "string",
                      "example": "Kinshasa"
                    },
                    "province": {
                      "type": "string",
                      "example": "Kinshasa"
                    },
                    "country": {
                      "type": "string",
                      "example": "DR Congo"
                    }
                  }
                },
                "phone": {
                  "type": "string",
                  "example": "+243810000000"
                }
              }
            }
          }
        ],
        "responses": {
          "201": {
            "description": "Created"
          },
          "400": {
            "description": "Bad Request"
          }
        }
      }
    },
    "/startups/{id}": {
      "get": {
        "tags": [
          "Startups Endpoints"
        ],
        "summary": "Get single startup",
        "description": "Pull one startup by ID from the database. ",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string",
            "description": "startup ID"
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "400": {
            "description": "Bad Request"
          },
          "404": {
            "description": "Not Found"
          }
        }
      },
      "put": {
        "tags": [
          "Startups Endpoints"
        ],
        "summary": "Update startup info",
        "description": "Edit a specific startup and save update in database. ",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string",
            "description": "Startup ID"
          },
          {
            "name": "body",
            "in": "body",
            "description": "Update startup data",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string",
                  "example": "KongoTech"
                },
                "description": {
                  "type": "string",
                  "example": "FinTech startup providing digital payment solutions"
                },
                "industry": {
                  "type": "string",
                  "example": "FinTech"
                },
                "founders": {
                  "type": "array",
                  "example": [
                    "Baron Mobs"
                  ],
                  "items": {
                    "type": "string"
                  }
                },
                "foundedYear": {
                  "type": "number",
                  "example": 2022
                },
                "location": {
                  "type": "object",
                  "properties": {
                    "ward": {
                      "type": "string",
                      "example": "Ngiri-Ngiri"
                    },
                    "stake": {
                      "type": "string",
                      "example": "Kinshasa"
                    },
                    "commune": {
                      "type": "string",
                      "example": "Ngiri-Ngiri"
                    },
                    "city": {
                      "type": "string",
                      "example": "Kinshasa"
                    },
                    "province": {
                      "type": "string",
                      "example": "Kinshasa"
                    },
                    "country": {
                      "type": "string",
                      "example": "DR Congo"
                    }
                  }
                },
                "phone": {
                  "type": "string",
                  "example": "+243810000000"
                },
                "email": {
                  "type": "string",
                  "example": "info@kongotech.com"
                },
                "website": {
                  "type": "string",
                  "example": "https://kongotech.com"
                },
                "products": {
                  "type": "array",
                  "example": [
                    "Mobile Wallet"
                  ],
                  "items": {
                    "type": "string"
                  }
                },
                "employees": {
                  "type": "number",
                  "example": 18
                },
                "startupStage": {
                  "type": "string",
                  "example": "Growth"
                },
                "fundingStage": {
                  "type": "string",
                  "example": "Seed"
                },
                "turnover": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "year": {
                        "type": "number",
                        "example": 2024
                      },
                      "amount": {
                        "type": "number",
                        "example": 65000
                      }
                    }
                  }
                }
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "400": {
            "description": "Bad Request"
          }
        }
      },
      "delete": {
        "tags": [
          "Startups Endpoints"
        ],
        "summary": "Delete startup",
        "description": "Delete selected startup from the database.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string",
            "description": "startup ID"
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "400": {
            "description": "Bad Request"
          }
        }
      }
    }
  }
}